# SAMI — Configuración OCR (ejemplo, sin claves reales)
# =======================================================
# Copia este archivo como ocr/.env o define las vars en el .env raíz.
# Las API keys (GEMINI_API_KEY, OCRSPACE_API_KEY) van en el .env raíz.

# ── Proveedor OCR activo ──
# gemini | tesseract | ocrspace
# OCR_PROVIDER=tesseract

# ── Google Gemini ──
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_TIMEOUT=30

# ── Tesseract (fallback local) ──
# TESSERACT_LANG=spa
# TESSERACT_SCALE=2.0
# TESSERACT_THRESHOLD=0
# TESSERACT_DENOISE=true
# TESSERACT_PSM=3

# ── OCR.space ──
# OCRSPACE_LANGUAGE=spa
# OCRSPACE_ENGINE=2
# OCRSPACE_TIMEOUT=30
