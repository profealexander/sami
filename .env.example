# SAMI — Ejemplo de configuracion (sin claves reales)
# =====================================================
# Copia este archivo como .env y completa tus claves.

# ── Entorno ──
ENV=development
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
CORS_ORIGINS=*

# ── Base de datos ──
# DATABASE_URL=sqlite:///./comprobantes.db
# DATABASE_URL=postgresql://usuario:pass@host:5432/sami

# ── Almacenamiento ──
# STORAGE_BACKEND=local
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# CLOUDINARY_URL=

# ── Proveedor OCR ──
# OCR_PROVIDER=gemini

# ── Google Gemini ──
# GEMINI_API_KEY=tu-api-key
# GEMINI_MODEL=gemini-2.0-flash

# ── OCR.space ──
# OCRSPACE_API_KEY=tu-api-key
# OCRSPACE_LANGUAGE=spa

# ── Directorio uploads ──
# UPLOAD_DIR=uploads
