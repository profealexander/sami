# SAMI — Ejemplo de configuracion (sin claves reales)
# =====================================================
# Copia este archivo como .env y completa tus claves.

# ── Entorno ──
ENV=development
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
CORS_ORIGINS=*

# ── Autenticación ──
# SAMI_API_KEY=tu_api_key_para_auth_aqui

# ── Base de datos ──
# DATABASE_URL=sqlite:///./comprobantes.db
# DATABASE_URL=postgresql://usuario:***@host:5432/sami
# POSTGRES_PASSWORD=cambia_esto_en_produccion

# ── Almacenamiento ──
# STORAGE_BACKEND=local
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# CLOUDINARY_URL=

# ── OCR ──
# Ver ocr/.env.example y ocr/config.toml para todos los parámetros OCR.
# Solo las API keys y rutas de sistema van aquí; el resto está en ocr/.env.
# GEMINI_API_KEY=tu-api-key
# OCRSPACE_API_KEY=tu-api-key

# ── Directorio uploads ──
# UPLOAD_DIR=uploads

# ── Validacion de uploads ──
# MAX_UPLOAD_SIZE_MB=10
# ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.webp

# ── Logging ──
# LOG_FILE=sami.log
